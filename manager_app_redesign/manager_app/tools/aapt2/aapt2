#!/data/data/com.termux/files/usr/bin/bash
# 在 Termux/arm64 上通过 qemu 运行 Google 官方新版 aapt2（x86_64）。
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
QEMU_BIN="/data/data/com.termux/files/usr/bin/qemu-x86_64"
RUNTIME_DIR="$SCRIPT_DIR/runtime-x86_64"
REAL_AAPT2="$SCRIPT_DIR/bin/aapt2-9.0.1-linux-x86_64"

if [[ ! -x "$QEMU_BIN" ]]; then
  echo "缺少 qemu-x86_64：$QEMU_BIN" >&2
  exit 1
fi
if [[ ! -x "$REAL_AAPT2" ]]; then
  echo "缺少官方 aapt2：$REAL_AAPT2" >&2
  exit 1
fi
if [[ ! -d "$RUNTIME_DIR" ]]; then
  echo "缺少 x86_64 运行时目录：$RUNTIME_DIR" >&2
  exit 1
fi

# 避免 Termux 注入的 LD_PRELOAD 污染 x86_64 进程。
exec env -u LD_PRELOAD "$QEMU_BIN" -L "$RUNTIME_DIR" "$REAL_AAPT2" "$@"
